{
  "name": "time-calculator",
  "version": "1.3.2",
  "description": "電腦使用時間追蹤應用程式",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable --x64",
    "dist": "electron-builder --publish=never",
    "clean": "rimraf dist node_modules/.cache",
    "release": "npm run build && git tag v$npm_package_version",
    "version": "git add package.json && git commit -m \"chore: bump version to v$npm_package_version\""
  },
  "keywords": [
    "timer",
    "productivity",
    "time-tracking"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.example.timecalculator",
    "productName": "時間計算器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json",
      "node_modules/axios/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": false,
      "verifyUpdateCodeSignature": false
    }
  },
  "dependencies": {
    "axios": "^1.10.0"
  }
}
