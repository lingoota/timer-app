{
  "name": "time-calculator",
  "version": "2.0.0-beta.17",
  "description": "電腦使用時間追蹤應用程式",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis --x64",
    "build-portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable --x64",
    "dist": "electron-builder --publish=never",
    "clean": "rimraf dist node_modules/.cache",
    "release": "npm run build && git tag v$npm_package_version",
    "version": "git add package.json && git commit -m \"chore: bump version to v$npm_package_version\""
  },
  "keywords": [
    "timer",
    "productivity",
    "time-tracking"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.3.11",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.lingoota.timecalculator",
    "productName": "時間計算器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json",
      "node_modules/axios/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "verifyUpdateCodeSignature": false,
      "publisherName": "Lingoota"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "時間計算器",
      "artifactName": "time-calculator-setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName} ${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "lingoota",
      "repo": "timer-app"
    }
  },
  "dependencies": {
    "axios": "^1.10.0",
    "electron-updater": "^6.7.3",
    "firebase": "^12.8.0",
    "mime-types": "^3.0.1"
  }
}
