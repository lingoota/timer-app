{
  "name": "time-calculator-universal",
  "version": "2.0.0",
  "description": "時間追蹤器 - 通用版 (支援Windows用戶自動登錄和多重存儲選擇)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable --x64",
    "dist": "electron-builder --publish=never",
    "clean": "rimraf dist node_modules/.cache",
    "release": "npm run build && git tag v$npm_package_version",
    "version": "git add package.json && git commit -m \"chore: bump version to v$npm_package_version\""
  },
  "keywords": [
    "timer",
    "productivity",
    "time-tracking"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.timetracker.universal",
    "productName": "時間追蹤器 Universal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json",
      "node_modules/axios/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": false,
      "verifyUpdateCodeSignature": false,
      "certificateFile": null,
      "certificatePassword": null,
      "requestedExecutionLevel": "asInvoker",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "時間追蹤器 Universal"
    },
    "portable": {
      "artifactName": "${productName} ${version}.${ext}"
    }
  },
  "dependencies": {
    "axios": "^1.10.0",
    "electron-store": "^10.1.0",
    "googleapis": "^153.0.0"
  }
}
